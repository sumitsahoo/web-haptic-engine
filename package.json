{
  "name": "web-haptic-engine",
  "version": "1.0.1",
  "description": "Cross-platform (iOS and Android) haptic feedback engine for the web",
  "keywords": [
    "android",
    "audio-impulse",
    "drag-haptics",
    "haptic-feedback",
    "haptics",
    "ios",
    "taptic",
    "touch-feedback",
    "vibration",
    "web-audio"
  ],
  "homepage": "https://github.com/sumitsahoo/web-haptic-engine#readme",
  "bugs": {
    "url": "https://github.com/sumitsahoo/web-haptic-engine/issues"
  },
  "license": "MIT",
  "author": "Sumit Sahoo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sumitsahoo/web-haptic-engine.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "demo": "vp dev --config demo/vite.config.ts",
    "test": "vp test",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260405.1",
    "bumpp": "^11.0.1",
    "typescript": "^6.0.2",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
